# Used for metadataBase, canonical URLs, Open Graph/Twitter absolute image
# URLs, and the sitemap.xml/robots.txt hosts. Set this to the real
# production domain once one exists — until then it falls back to
# http://localhost:3000 in code.
NEXT_PUBLIC_SITE_URL=https://TODO-set-real-domain.example

# Base URL of the FastAPI backend (see ../backend). Defaults to the local
# docker-compose API if unset.
NEXT_PUBLIC_API_URL=http://localhost:8000
